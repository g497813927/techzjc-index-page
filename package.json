{
  "name": "web-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate-licenses": "node ./scripts/generate-licenses.mjs",
    "prepare-env": "echo NEXT_PUBLIC_COMMIT_SHA=$(git rev-parse --short HEAD) > .env.local && echo NEXT_PUBLIC_BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ) >> .env.local && npm run generate-licenses",
    "dev": "npm run prepare-env && next dev",
    "build": "npm run prepare-env && next build",
    "build:docker": "npm run prepare-env && next build --webpack && node ./scripts/sanitize-next-static-paths.mjs",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@formatjs/intl-localematcher": "^0.8.3",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@mdx-js/loader": "3.1.1",
    "@mdx-js/mdx": "3.1.1",
    "@mdx-js/react": "3.1.1",
    "@next/mdx": "^16.2.2",
    "@next/third-parties": "^16.2.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "figlet": "^1.11.0",
    "github-markdown-css": "^5.9.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "license-checker": "^25.0.1",
    "lightningcss": "1.32.0",
    "motion": "^12.38.0",
    "negotiator": "^1.0.0",
    "next": "^16.2.3",
    "next-mdx-remote": "^6.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.5",
    "rehype-github-alerts": "^4.1.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "vconsole": "^3.15.1"
  },
  "optionalDependencies": {
    "@giscus/react": "^3.1.0",
    "@tailwindcss/oxide-linux-x64-gnu": "^4.2.2",
    "lightningcss-linux-x64-gnu": "^1.32.0"
  },
  "devDependencies": {
    "typescript": "^6",
    "@next/bundle-analyzer": "^16.2.3",
    "@tailwindcss/postcss": "^4",
    "@types/estree": "^1.0.8",
    "@types/ms": "^2.1.0",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^25",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-helmet": "^6.1.11",
    "@types/unist": "^3.0.3",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.2.3",
    "tailwindcss": "^4"
  },
  "overrides": {
    "ajv": ">=8.18.0",
    "minimatch": ">=10.2.1"
  },
  "browserslist": [
    "last 2 chrome versions",
    "last 2 firefox versions",
    "last 2 edge versions",
    "last 2 safari versions",
    "not IE 11",
    "not op_mini all"
  ]
}
